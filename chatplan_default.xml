<?xml version="1.0" encoding="utf-8"?>
<include>
  <context name="default">

    <!-- OUTGOING: SMS from 101/102 to mobile (via gateway1) -->
    <!-- Check FIRST because from=10X is more specific than from=phone_number -->
    <extension name="sms_to_mobile_gw1">
      <condition field="from" expression="^10[12]@" break="on-false"/>
      <condition field="to" expression="^(\+?[78]9\d{9})@">
        <action application="set" data="to=$1@${regex(${sofia_contact(gateway1@m.e-bash.ru)}|sip:[^@]+@([^;]+;transport=TLS)|%1)}"/>
        <action application="fire"/>
      </condition>
    </extension>

    <!-- OUTGOING: SMS from 103/104 to mobile (via gateway2) -->
    <extension name="sms_to_mobile_gw2">
      <condition field="from" expression="^10[34]@" break="on-false"/>
      <condition field="to" expression="^(\+?[78]9\d{9})@">
        <action application="set" data="to=$1@${regex(${sofia_contact(gateway2@m.e-bash.ru)}|sip:[^@]+@([^;]+;transport=TLS)|%1)}"/>
        <action application="fire"/>
      </condition>
    </extension>

    <!-- INCOMING: SMS from phone number to 101/102 (from gateway1) -->
    <extension name="sms_from_gateway1">
      <condition field="from" expression="^\+?[78]?9\d{9}@" break="on-false"/>
      <condition field="to" expression="^(10[12])@">
        <action application="system" data="/opt/freeswitch/scripts/sms_forward.sh '${from_user}' '${to_user}' '${_body}'"/>
        <action application="set" data="to=${to_user}@m.e-bash.ru"/>
        <action application="fire"/>
      </condition>
    </extension>

    <!-- INCOMING: SMS from phone number to 103/104 (from gateway2) -->
    <extension name="sms_from_gateway2">
      <condition field="from" expression="^\+?[78]?9\d{9}@" break="on-false"/>
      <condition field="to" expression="^(10[34])@">
        <action application="system" data="/opt/freeswitch/scripts/sms_forward.sh '${from_user}' '${to_user}' '${_body}'"/>
        <action application="set" data="to=${to_user}@m.e-bash.ru"/>
        <action application="fire"/>
      </condition>
    </extension>

    <!-- SMS to internal extensions (catch-all for internal) -->
    <extension name="sms_internal">
      <condition field="to" expression="^(10[0-4])@">
        <action application="set" data="to=${to_user}@m.e-bash.ru"/>
        <action application="fire"/>
      </condition>
    </extension>

  </context>
</include>
